# Copy to .env.local and fill in actual values. .env.local is gitignored.
# See docs/deployment/ for full explanations of each variable.

# ──────────────── Authentication ────────────────
# REQUIRED when LISTEN_ADDR is not loopback. Without these the process
# refuses to bind a non-loopback port.
# Generate strong random values, for example:
#   openssl rand -hex 8         # username
#   openssl rand -base64 36     # password (strip +/=)
PROXY_USERNAME=
PROXY_PASSWORD=

# ──────────────── Networking ────────────────
# Bind address. Use 0.0.0.0 for Docker/Railway/Kubernetes exposure.
# Leave as 127.0.0.1 for local-only use (the default).
LISTEN_ADDR=0.0.0.0
LISTEN_PORT=3128

# Admin port (/healthz, /readyz, /startupz, /pool, /metrics). Keep
# internal — do not expose publicly unless behind additional auth.
ADMIN_ADDR=0.0.0.0
ADMIN_PORT=8080

# ──────────────── Validation target ────────────────
# URL used to verify each candidate proxy actually works. IMPORTANT:
# do NOT point this at the site you intend to crawl. Every candidate
# in every fetch cycle hits this URL, so pointing it at the real
# target floods that target with thousands of requests from different
# IPs — which looks like a distributed attack and encourages the
# target to tighten its blocking. Use a neutral endpoint.
#
# Recommended:
#   https://www.cloudflare.com/cdn-cgi/trace   (returns 200, huge CDN, safe)
#   https://www.google.com/generate_204         (204 by design; check handler expects 200)
TEST_URL=https://www.cloudflare.com/cdn-cgi/trace
TEST_TIMEOUT=8s

# If set, the response body must contain this string. Useful to filter
# proxies that return CAPTCHA / block pages with 200 status. Leave
# empty for plain status-code validation.
VERIFY_MATCH_BODY=

# ──────────────── Pool ────────────────
POOL_MIN=5
POOL_MAX=50
EJECT_CONSEC_FAILS=2
QUARANTINE_DURATION=5m

# ──────────────── Sources ────────────────
SOURCES=freeproxy

# freeproxy plugin
SOURCE_FREEPROXY_URL=https://raw.githubusercontent.com/TheSpeedX/PROXY-List/master/socks5.txt
SOURCE_FREEPROXY_INTERVAL=30m
SOURCE_FREEPROXY_INTERVAL_LOW=5m
SOURCE_FREEPROXY_CONCURRENCY=10
SOURCE_FREEPROXY_HTTP_TIMEOUT=30s

# file plugin (unused by default, enable via SOURCES=file,freeproxy)
SOURCE_FILE_PATH=/etc/proxy-rotator/proxies.txt
SOURCE_FILE_INTERVAL=60s
SOURCE_FILE_CONCURRENCY=10

# ──────────────── Request handling ────────────────
MAX_RETRIES=2
PER_PROXY_TIMEOUT=8s
TOTAL_TIMEOUT=30s

# Routing policy
MATCH_HOSTS=
BYPASS_HOSTS=.cluster.local,.svc,localhost
DEFAULT_ACTION=proxy

# ──────────────── Security ────────────────
# Leave false. Setting true disables the SSRF guard that blocks targets
# resolving to RFC1918 / loopback / link-local / cloud metadata IPs.
ALLOW_PRIVATE_TARGETS=false

# HTTP server hardening
READ_HEADER_TIMEOUT=5s
IDLE_TIMEOUT=120s
MAX_HEADER_BYTES=1048576
MAX_REQUEST_BODY=10485760
STARTUP_GRACE=30s

# ──────────────── Logging ────────────────
LOG_LEVEL=info
